{
	"name": "masterbelt.github.io",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"typecheck": "velite && tsc --noEmit",
		"check": "biome check",
		"check:fix": "biome check --write",
		"lint:i18n": "eslint .",
		"lint:md": "prettier --check \"**/*.md\"",
		"prepare": "husky"
	},
	"license": "MIT",
	"packageManager": "pnpm@11.5.2",
	"type": "module",
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"src/**/*.{ts,tsx}": [
			"eslint --max-warnings=0"
		],
		"*.md": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@sanity/eslint-config-i18n": "^2.0.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^25.9.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/parser": "^8.61.0",
		"commitlint-config-agent-coauthor": "^1.0.0",
		"eslint": "^10.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"velite": "^0.3.1"
	},
	"dependencies": {
		"i18next": "^26.3.1",
		"lucide-react": "^1.17.0",
		"next": "^16.2.7",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8"
	}
}
