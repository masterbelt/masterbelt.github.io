{
  "name": "masterbelt-github-io",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-search-index.mjs && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server --emptyOutDir false && node scripts/generate-static-routes.mjs && node scripts/generate-llms-txt.mjs && node scripts/generate-sitemap.mjs",
    "generate:spec": "node scripts/generate-spec.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "check": "tsc -b",
    "biome:check": "biome check .",
    "biome:write": "biome check --write .",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "mermaid": "^11.15.0",
    "minisearch": "^7.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
