{
	"name": "masterbelt.github.io",
	"private": true,
	"scripts": {
		"grammars": "node scripts/build-grammars.mjs",
		"dev": "pnpm grammars && next dev",
		"build": "pnpm grammars && next build",
		"typecheck": "pnpm grammars && velite && tsc --noEmit",
		"check": "biome check",
		"check:fix": "biome check --write",
		"lint:i18n": "eslint .",
		"lint:md": "prettier --check \"**/*.md\"",
		"prepare": "husky"
	},
	"license": "MIT",
	"packageManager": "pnpm@11.5.2",
	"type": "module",
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"src/**/*.{ts,tsx}": [
			"eslint --max-warnings=0"
		],
		"*.md": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@sanity/eslint-config-i18n": "^2.0.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tree-sitter-grammars/tree-sitter-toml": "^0.7.0",
		"@types/node": "^25.9.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/parser": "^8.61.0",
		"commitlint-config-agent-coauthor": "^1.0.0",
		"eslint": "^10.4.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"rehype-mermaid": "^3.0.0",
		"tailwindcss": "^4.3.0",
		"tree-sitter-c-sharp": "^0.23.5",
		"tree-sitter-go": "^0.25.0",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-typescript": "^0.23.2",
		"typescript": "^6.0.3",
		"velite": "^0.3.1",
		"web-tree-sitter": "^0.26.9"
	},
	"dependencies": {
		"i18next": "^26.3.1",
		"katex": "^0.17.0",
		"lucide-react": "^1.17.0",
		"next": "^16.2.7",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8",
		"rehype-katex": "^7.0.1",
		"remark-emoji": "^5.0.2",
		"remark-github-blockquote-alert": "^2.1.0",
		"remark-math": "^6.0.0"
	}
}
